# Adler env keys — copy to .env.local (gitignored) and fill in real values.

# === Public (bundled into the mobile build) ===
EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_APP_ID=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=
EXPO_PUBLIC_FIREBASE_MEASUREMENT_ID=
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
EXPO_PUBLIC_FIREBASE_PROJECT_ID=
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=
EXPO_PUBLIC_PRIVY_APP_ID=
EXPO_PUBLIC_PRIVY_CLIENT_ID=
# Web App Check (Phase 3 M11). Leave unset to skip web App Check init.
EXPO_PUBLIC_RECAPTCHA_ENTERPRISE_SITE_KEY=

# === Cloud Functions secrets (set via `firebase functions:secrets:set`) ===
