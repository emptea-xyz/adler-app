rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // Avatar pictures: owner-only write, public read, JPEG ≤ 2 MB.
    match /profilePictures/{fileName} {
      allow read: if true;
      allow write: if request.auth != null
                   && fileName == request.auth.uid + '.jpg'
                   && request.resource.size < 2 * 1024 * 1024
                   && request.resource.contentType == 'image/jpeg';
    }

    function validBountySubmissionUpload() {
      return (request.resource.contentType.matches('image/.*')
              && request.resource.size < 8 * 1024 * 1024)
             || (request.resource.contentType in ['video/mp4', 'video/quicktime']
                 && request.resource.size < 100 * 1024 * 1024);
    }

    // Bounty submission media: owner-only write, public read. Photos are
    // raster ≤ 8 MB; MVP videos are mp4/quicktime ≤ 100 MB.
    match /bountySubmissions/{userId}/{fileName} {
      allow read: if true;
      allow write: if request.auth != null
                   && request.auth.uid == userId
                   && validBountySubmissionUpload();
    }

    // Group avatars: public read, authed write, JPEG ≤ 2 MB. Admin gating
    // happens in the `updateGroup` Cloud Function — non-admins can upload
    // but can't bind the URL onto the group doc.
    match /groupLogos/{groupId}/{fileName} {
      allow read: if true;
      allow write: if request.auth != null
                   && request.resource.size < 2 * 1024 * 1024
                   && request.resource.contentType == 'image/jpeg';
    }
  }
}
