rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // Avatar pictures: owner-only write, public read, JPEG ≤ 2 MB.
    match /profilePictures/{fileName} {
      allow read: if true;
      allow write: if request.auth != null
                   && fileName == request.auth.uid + '.jpg'
                   && request.resource.size < 2 * 1024 * 1024
                   && request.resource.contentType == 'image/jpeg';
    }

    // Bounty submission photos: owner-only write, public read (the
    // verifier Cloud Function fetches the public URL), raster only ≤ 8 MB.
    match /bountySubmissions/{userId}/{fileName} {
      allow read: if true;
      allow write: if request.auth != null
                   && request.auth.uid == userId
                   && request.resource.size < 8 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
    }
  }
}
