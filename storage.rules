rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Profile avatars: anyone can read; user only writes/deletes their own.
    match /profilePictures/{fileName} {
      allow read: if true;
      allow create, update: if request.auth != null
        && fileName == request.auth.uid + '.jpg'
        && request.resource.contentType == 'image/jpeg'
        && request.resource.size <= 2 * 1024 * 1024;
      allow delete: if request.auth != null
        && fileName == request.auth.uid + '.jpg';
    }

    // Marketplace media: each seller/applicant uploads under their own uid prefix.
    // Public read so listings can render without authentication. Whitelist
    // raster MIME types only — `image/.*` would let SVG through, which can
    // execute scripts when rendered in <img> tags.
    function isSafeRasterImage() {
      return request.resource.contentType in
        ['image/jpeg', 'image/png', 'image/webp'];
    }
    // Listing media (services + gigs) accepts both stills and short-form
    // video — UGC creators sell themselves with testimonial clips and
    // example reels, so image-only is too restrictive. The firestore rule
    // caps each listing doc at 5 entries; per-file size is gated here.
    function isSafeListingMedia() {
      return request.resource.contentType in
        ['image/jpeg', 'image/png', 'image/webp',
         'video/mp4', 'video/webm', 'video/quicktime'];
    }
    match /packages/{userId}/{fileName} {
      allow read: if true;
      allow write: if request.auth != null
        && request.auth.uid == userId
        && isSafeRasterImage()
        && request.resource.size <= 8 * 1024 * 1024;
    }
    match /services/{userId}/{fileName} {
      allow read: if true;
      allow write: if request.auth != null
        && request.auth.uid == userId
        && isSafeListingMedia()
        && request.resource.size <= 50 * 1024 * 1024;
    }
    match /gigs/{userId}/{fileName} {
      allow read: if true;
      allow write: if request.auth != null
        && request.auth.uid == userId
        && isSafeListingMedia()
        && request.resource.size <= 50 * 1024 * 1024;
    }
    match /applications/{userId}/{fileName} {
      allow read: if true;
      allow write: if request.auth != null
        && request.auth.uid == userId
        && isSafeRasterImage()
        && request.resource.size <= 8 * 1024 * 1024;
    }
  }
}
