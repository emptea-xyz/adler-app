{
  "$schema": "https://unpkg.com/knip@5/schema.json",
  "workspaces": {
    ".": {
      "entry": ["app/**/*.{ts,tsx}", "index.js"]
    }
  },
  "entry": [
    "app/**/*.{ts,tsx}"
  ],
  "ignoreWorkspaces": ["functions"],
  "ignore": [
    "functions/**",
    "components/ui/charts/**",
    "components/ui/{Alert,Avatar,BottomSheet,Dropdown,ErrorState,FadeTransition,HapticRefreshControl,NumberInput,PopoverMenu,ProgressBar,ScreenFadeIn,SegmentedToggle,Skeleton,UnderlineTabBar}.tsx",
    "components/ui/icons/**",
    "constants/{ComponentTheme,ThemeColors}.ts",
    "hooks/{useAsyncState,useDebounce}.ts",
    "lib/utils/{array,avatars,chartNarrative,dates,firestore,formatNumber,withTimeout}.ts",
    "lib/services/imageUploadService.ts",
    "types/{components,navigation}.ts"
  ],
  "ignoreDependencies": [
    "babel-plugin-transform-remove-console",
    "buffer",
    "jose"
  ],
  "ignoreBinaries": [
    "expo"
  ]
}
