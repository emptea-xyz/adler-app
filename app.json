{
  "expo": {
    "owner": "m2dt",
    "name": "adler",
    "slug": "adler",
    "version": "0.1.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "adler",
    "userInterfaceStyle": "automatic",
    "platforms": [
      "ios",
      "web"
    ],
    "ios": {
      "googleServicesFile": "./GoogleService-Info.plist",
      "bundleIdentifier": "com.m2dt.adler",
      "appleTeamId": "8Q97322X2M",
      "supportsTablet": false,
      "usesAppleSignIn": true,
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "plugins": [
      "expo-router",
      [
        "expo-font",
        {
          "fonts": []
        }
      ],
      [
        "expo-web-browser",
        {
          "dismissButtonStyle": "done"
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#FFFFFF"
        }
      ],
      [
        "expo-build-properties",
        {
          "ios": {
            "deploymentTarget": "15.1",
            "extraPods": [
              {
                "name": "FirebaseCore",
                "modular_headers": true
              },
              {
                "name": "FirebaseCoreInternal",
                "modular_headers": true
              },
              {
                "name": "GoogleUtilities",
                "modular_headers": true
              }
            ]
          }
        }
      ],
      "expo-image",
      [
        "expo-image-picker",
        {
          "photosPermission": "Adler needs access to your photos so you can upload media for the packages and gigs you list.",
          "cameraPermission": "Adler needs camera access so you can capture media for the packages and gigs you list."
        }
      ],
      "expo-asset",
      "expo-apple-authentication",
      [
        "expo-secure-store",
        {
          "faceIDPermission": "Adler uses Face ID to keep your wallet secure."
        }
      ],
      "@react-native-firebase/app",
      "@react-native-firebase/app-check",
      "expo-video",
      [
        "expo-notifications",
        {
          "icon": "./assets/images/icon.png",
          "color": "#0a0a0a",
          "defaultChannel": "default"
        }
      ]
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "f1c5c2e1-8379-44c3-800b-8de2956f6769"
      }
    }
  }
}
