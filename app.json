{
  "expo": {
    "owner": "m2dt",
    "name": "adler",
    "slug": "adler",
    "version": "0.1.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "adler",
    "userInterfaceStyle": "automatic",
    "ios": {
      "googleServicesFile": "./GoogleService-Info.plist",
      "bundleIdentifier": "com.m2dt.adler",
      "appleTeamId": "8Q97322X2M",
      "supportsTablet": false,
      "usesAppleSignIn": true,
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.m2dt.adler",
      "googleServicesFile": "./google-services.json",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "adler",
              "host": "auth"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-font",
        {
          "fonts": []
        }
      ],
      [
        "expo-web-browser",
        {
          "dismissButtonStyle": "done"
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#FFFFFF"
        }
      ],
      [
        "expo-build-properties",
        {
          "android": {
            "minSdkVersion": 24
          },
          "ios": {
            "deploymentTarget": "15.1",
            "extraPods": [
              {
                "name": "FirebaseCoreInternal",
                "modular_headers": true
              },
              {
                "name": "GoogleUtilities",
                "modular_headers": true
              }
            ]
          }
        }
      ],
      "expo-image",
      [
        "expo-image-picker",
        {
          "photosPermission": "Adler needs access to your photos so you can upload media for the packages and gigs you list.",
          "cameraPermission": "Adler needs camera access so you can capture media for the packages and gigs you list."
        }
      ],
      "expo-asset",
      [
        "expo-secure-store",
        {
          "faceIDPermission": "Adler uses Face ID to keep your wallet secure."
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "REPLACE_WITH_NEW_EAS_PROJECT_ID"
      },
      "router": {}
    },
    "runtimeVersion": {
      "policy": "appVersion"
    }
  }
}
