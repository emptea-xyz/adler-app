rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthed() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isAuthed() && request.auth.uid == uid;
    }

    // ── Profiles ────────────────────────────────────────────────────────
    // Public read; owner-only write with field validation.
    function validUsername(v) {
      return v is string && v.matches('^[a-z0-9_]{3,20}$');
    }
    function validDisplayName(v) {
      return v is string && v.size() > 0 && v.size() <= 50;
    }
    function validBio(v) {
      return v is string && v.size() <= 280;
    }
    function validLocation(v) {
      return v is map && v.kind in ['city', 'global'] &&
             (v.kind == 'global'
                || (v.city is string && v.city.size() > 0 && v.city.size() <= 60 &&
                    v.country is string && v.country.size() == 2));
    }

    match /profiles/{userId} {
      allow read: if true;
      allow create: if isOwner(userId)
                    && request.resource.data.id == userId
                    && validUsername(request.resource.data.username)
                    && validDisplayName(request.resource.data.displayName)
                    && validBio(request.resource.data.bio);
      allow update: if isOwner(userId)
                    // Append-only walletAddress.
                    && (resource.data.walletAddress == null
                        || request.resource.data.walletAddress == resource.data.walletAddress)
                    && validUsername(request.resource.data.username)
                    && validDisplayName(request.resource.data.displayName)
                    && validBio(request.resource.data.bio)
                    && validLocation(request.resource.data.location)
                    // groupCount + latestActivityAt are server-only fields.
                    && (request.resource.data.groupCount == resource.data.get('groupCount', 0));
      allow delete: if false;
    }

    match /usernames/{slug} {
      allow read: if true;
      allow create: if isAuthed()
                    && request.resource.data.userId == request.auth.uid
                    && slug.matches('^[a-z0-9_]{3,20}$');
      allow update: if false;
      allow delete: if isAuthed() && resource.data.userId == request.auth.uid;
    }

    // ── Bounties ────────────────────────────────────────────────────────
    function bountyValidShape(d) {
      return d.posterId is string
             && d.title is string && d.title.size() > 0 && d.title.size() <= 80
             && d.prompt is string && d.prompt.size() > 0 && d.prompt.size() <= 500
             && d.mode in ['manual', 'auto']
             && d.bountyLamports is int && d.bountyLamports > 0
             && d.scope in ['public', 'group']
             && d.contractIdHex is string && d.contractIdHex.size() == 64
             && d.posterWalletAddress is string;
    }

    match /bounties/{id} {
      // Hidden bounties only visible to poster + super-admin queue (server).
      allow read: if resource.data.status != 'hidden'
                  || isOwner(resource.data.posterId);
      allow create: if isOwner(request.resource.data.posterId)
                    && bountyValidShape(request.resource.data)
                    && request.resource.data.status == 'open'
                    && request.resource.data.reportCount == 0
                    && request.resource.data.escrowFunded == false
                    && (request.resource.data.scope == 'public'
                        || (request.resource.data.scope == 'group'
                            && request.resource.data.groupId is string));
      // Owner can flip escrowFunded flag once (after on-chain create_bounty).
      // All other status / winner / settlement fields are Cloud-Function-only.
      allow update: if isOwner(resource.data.posterId)
                    && resource.data.status == 'open'
                    && request.resource.data.posterId == resource.data.posterId
                    && request.resource.data.bountyLamports == resource.data.bountyLamports
                    && request.resource.data.contractIdHex == resource.data.contractIdHex
                    && request.resource.data.status == resource.data.status
                    && request.resource.data.reportCount == resource.data.reportCount;
      allow delete: if false;
    }

    // ── Submissions ─────────────────────────────────────────────────────
    match /submissions/{id} {
      allow read: if true;
      allow create: if isOwner(request.resource.data.submitterId)
                    && request.resource.data.bountyId is string
                    && request.resource.data.photoUrl is string
                    && request.resource.data.aiVerdict == null
                    && request.resource.data.isWinner == false;
      // Submitter can delete their own submission only before a verdict
      // lands (i.e. before the verifier writes aiVerdict).
      allow update: if false;
      allow delete: if isOwner(resource.data.submitterId)
                    && resource.data.aiVerdict == null;
    }

    // ── Reports ─────────────────────────────────────────────────────────
    // Deterministic doc id: ${bountyId}_${reporterId}.
    match /reports/{id} {
      allow read: if isOwner(resource.data.reporterId);
      allow create: if isOwner(request.resource.data.reporterId)
                    && request.resource.data.bountyId is string
                    && request.resource.data.reason is string
                    && request.resource.data.reason.size() > 0
                    && request.resource.data.reason.size() <= 200
                    && id == request.resource.data.bountyId + '_' + request.auth.uid;
      allow update: if false;
      allow delete: if false;
    }

    // ── Groups ──────────────────────────────────────────────────────────
    match /groups/{id} {
      allow read: if isAuthed();
      // Server-only writes (Cloud Function approveGroupCreation).
      allow create, update, delete: if false;
    }

    match /groupMembers/{compoundId} {
      // Members read their own membership doc; admins read any in their group.
      allow read: if isAuthed()
                  && (resource.data.uid == request.auth.uid
                      || (exists(/databases/$(database)/documents/groupMembers/$(resource.data.groupId + '_' + request.auth.uid))
                          && get(/databases/$(database)/documents/groupMembers/$(resource.data.groupId + '_' + request.auth.uid)).data.role == 'admin'));
      // All writes are server-only. Super-admin seeds 'admin' role via
      // direct Firestore writes (bypasses rules).
      allow create, update, delete: if false;
    }

    match /joinRequests/{id} {
      allow read: if isAuthed()
                  && (resource.data.uid == request.auth.uid
                      || (exists(/databases/$(database)/documents/groupMembers/$(resource.data.groupId + '_' + request.auth.uid))
                          && get(/databases/$(database)/documents/groupMembers/$(resource.data.groupId + '_' + request.auth.uid)).data.role == 'admin'));
      // Deterministic doc id: ${groupId}_${uid}.
      allow create: if isOwner(request.resource.data.uid)
                    && request.resource.data.groupId is string
                    && request.resource.data.status == 'pending'
                    && id == request.resource.data.groupId + '_' + request.auth.uid;
      // Admin approve/reject is server-only.
      allow update, delete: if false;
    }

    match /groupCreationRequests/{id} {
      allow read: if isOwner(resource.data.requesterId);
      allow create: if isOwner(request.resource.data.requesterId)
                    && request.resource.data.name is string
                    && request.resource.data.name.size() > 0
                    && request.resource.data.name.size() <= 60
                    && request.resource.data.description is string
                    && request.resource.data.description.size() <= 200
                    && request.resource.data.status == 'pending';
      allow update, delete: if false;
    }

    // ── Notifications ───────────────────────────────────────────────────
    match /notifications/{id} {
      allow read: if isOwner(resource.data.recipientId);
      // Owner can flip read flag only.
      allow update: if isOwner(resource.data.recipientId)
                    && request.resource.data.recipientId == resource.data.recipientId
                    && request.resource.data.kind == resource.data.kind
                    && request.resource.data.title == resource.data.title
                    && request.resource.data.body == resource.data.body
                    && request.resource.data.href == resource.data.href
                    && request.resource.data.refs == resource.data.refs;
      // Server-only create + delete.
      allow create, delete: if false;
    }

    // ── Preferences ─────────────────────────────────────────────────────
    match /preferences/{uid} {
      allow read, write: if isOwner(uid);
    }
  }
}
