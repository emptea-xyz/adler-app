rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthed() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isAuthed() && request.auth.uid == uid;
    }

    // Arbiter role lookup. `roles/{uid}` is server-only writeable (admin
    // SDK or firebase-cli) — there's no UI for assigning arbiters in v1.
    // Used by the disputes block + the threads/messages reads to grant
    // arbiters evidence-only access to the message log.
    function isArbiter() {
      return isAuthed() &&
             exists(/databases/$(database)/documents/roles/$(request.auth.uid)) &&
             get(/databases/$(database)/documents/roles/$(request.auth.uid)).data.role == 'arbiter';
    }

    // Profiles are public-readable so listings can show seller info; writes
    // only by the profile owner. Updates are field-validated so a tampered
    // client can't write a 10MB displayName or a `<script>` username.
    function validProfileUsername(value) {
      return value is string && value.matches('^[a-z0-9_]{3,20}$');
    }
    function validProfileDisplayName(value) {
      return value is string && value.size() > 0 && value.size() <= 50;
    }
    function validProfileBio(value) {
      return value is string && value.size() <= 280;
    }
    function validProfileAvatarUrl(value) {
      return value == null || (value is string && value.size() <= 2048);
    }
    function validProfileRole(value) {
      return value == null || value in ['creator', 'brand'];
    }
    function validProfilePushToken(value) {
      return value == null || (value is string && value.size() > 0 && value.size() <= 256);
    }
    // ISO-3166-1 alpha-2 OR null (= "Global"). Two letters, A-Z only —
    // case-strict; the web client always uppercases before writing.
    function validProfileCountry(value) {
      return value == null ||
             (value is string && value.matches('^[A-Z]{2}$'));
    }
    // Cold-DM opt-in contact channels. Each field is independently nullable;
    // an entirely empty contact must be persisted as `null` rather than
    // `{email:null,telegram:null,phone:null}` so directory queries can use
    // a simple presence check. Length caps are deliberately generous —
    // these strings are user-typed and we don't validate format server-side.
    function validProfileDmContact(value) {
      return value == null || (
        value is map &&
        value.keys().hasOnly(['email', 'telegram', 'phone']) &&
        (value.email == null ||
         (value.email is string && value.email.size() > 0 && value.email.size() <= 254)) &&
        (value.telegram == null ||
         (value.telegram is string && value.telegram.size() > 0 && value.telegram.size() <= 32)) &&
        (value.phone == null ||
         (value.phone is string && value.phone.size() > 0 && value.phone.size() <= 20))
      );
    }
    // Creator side: null = no Creator presence. Otherwise: niches list
    // (size 0-6; per-element validation is left to the client, see
    // `lib/utils/niches.ts` in the web app — Firestore rules can't easily
    // map() over a list, and the worst case is one ugly chip in the UI),
    // optional portfolioUrl string ≤ 2048 chars, and optional socialLinks
    // list (size ≤ 16; per-element shape validated client-side).
    function validProfileCreator(value) {
      return value == null || (
        value is map &&
        value.keys().hasOnly(['niches', 'portfolioUrl', 'socialLinks', 'dmContact']) &&
        value.niches is list &&
        value.niches.size() <= 6 &&
        (value.portfolioUrl == null ||
         (value.portfolioUrl is string && value.portfolioUrl.size() <= 2048)) &&
        (!('socialLinks' in value) ||
         (value.socialLinks is list && value.socialLinks.size() <= 16)) &&
        (!('dmContact' in value) || validProfileDmContact(value.dmContact))
      );
    }
    // Brand side: null = no Brand presence. Otherwise: companyName (1-60),
    // optional industry (≤ 60), optional websiteUrl (≤ 2048).
    function validProfileBrand(value) {
      return value == null || (
        value is map &&
        value.keys().hasOnly(['companyName', 'industry', 'websiteUrl', 'dmContact']) &&
        value.companyName is string &&
        value.companyName.size() > 0 &&
        value.companyName.size() <= 60 &&
        (value.industry == null ||
         (value.industry is string && value.industry.size() <= 60)) &&
        (value.websiteUrl == null ||
         (value.websiteUrl is string && value.websiteUrl.size() <= 2048)) &&
        (!('dmContact' in value) || validProfileDmContact(value.dmContact))
      );
    }
    // Denormalized role flags must mirror the corresponding sub-profile
    // presence so directory queries (`where("isBrand","==",true)`) can't be
    // tampered into surfacing users who haven't actually set up that side.
    function validProfileRoleFlag(value, subProfile) {
      return value is bool && value == (subProfile != null);
    }
    // Per-user "saved listings" — like a bookmark. Doc id is deterministic
    // (`${userId}_${kind}_${listingId}`) so a tampered client can't masquerade
    // saves under another user.
    match /saves/{saveId} {
      allow read: if isAuthed() && resource.data.userId == request.auth.uid;
      allow create: if isAuthed() &&
                      request.resource.data.userId == request.auth.uid &&
                      saveId == request.resource.data.userId + '_' + request.resource.data.kind + '_' + request.resource.data.listingId &&
                      request.resource.data.kind in ['service', 'gig'] &&
                      request.resource.data.listingId is string &&
                      request.resource.data.listingId.size() > 0;
      allow update: if false;
      allow delete: if isAuthed() && resource.data.userId == request.auth.uid;
    }

    // Username reservations. Doc id is the lowercase slug; data carries the
    // claiming userId. Anyone can read (so clients can check availability);
    // only the owner can create/release. Slug regex matches the profile rule.
    match /usernames/{slug} {
      allow read: if true;
      allow create: if isAuthed() &&
                      request.resource.data.userId == request.auth.uid &&
                      slug.matches('^[a-z0-9_]{3,20}$');
      allow update: if isAuthed() && resource.data.userId == request.auth.uid;
      allow delete: if isAuthed() && resource.data.userId == request.auth.uid;
    }
    match /profiles/{userId} {
      allow read: if true;
      allow create: if isOwner(userId);
      // Validate each field only when it's actually being changed, so legacy
      // profiles created before these caps existed aren't locked out.
      allow update: if isOwner(userId)
                      && request.resource.data.diff(resource.data).affectedKeys()
                        .hasOnly([
                          'username', 'displayName', 'bio', 'avatarUrl',
                          'role', 'walletAddress', 'pushToken',
                          'country', 'creatorProfile', 'brandProfile',
                          'isCreator', 'isBrand',
                          'updatedAt',
                        ])
                      && (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['username'])
                          || validProfileUsername(request.resource.data.username))
                      && (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['displayName'])
                          || validProfileDisplayName(request.resource.data.displayName))
                      && (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['bio'])
                          || validProfileBio(request.resource.data.bio))
                      && (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['avatarUrl'])
                          || validProfileAvatarUrl(request.resource.data.avatarUrl))
                      && (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['role'])
                          || validProfileRole(request.resource.data.role))
                      && (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['pushToken'])
                          || validProfilePushToken(request.resource.data.pushToken))
                      && (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['country'])
                          || validProfileCountry(request.resource.data.country))
                      && (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['creatorProfile'])
                          || validProfileCreator(request.resource.data.creatorProfile))
                      && (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['brandProfile'])
                          || validProfileBrand(request.resource.data.brandProfile))
                      && (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['isCreator'])
                          || validProfileRoleFlag(request.resource.data.isCreator, request.resource.data.creatorProfile))
                      && (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['isBrand'])
                          || validProfileRoleFlag(request.resource.data.isBrand, request.resource.data.brandProfile))
                      // walletAddress is append-only: null → string, but never overwritten.
                      && (
                        resource.data.walletAddress == null ||
                        resource.data.walletAddress == request.resource.data.walletAddress
                      );
      allow delete: if false;
    }

    // Active services are public-readable; only the seller can mutate. Sellers
    // can also read their own paused/sold listings.
    function validListingMediaUrls(value) {
      // Optional. Up to 5 string URLs (storage download links). Per-item
      // length cap matches Firestore's practical string limit; we don't
      // attempt to validate URL shape here — the storage rule does that
      // gating at upload time.
      return !('mediaUrls' in value) || (
        value.mediaUrls is list &&
        value.mediaUrls.size() <= 5
      );
    }
    match /services/{serviceId} {
      allow read: if (resource == null || resource.data.status == 'active') ||
                     (isAuthed() && resource.data.sellerId == request.auth.uid);
      allow create: if isAuthed() &&
                      request.resource.data.sellerId == request.auth.uid &&
                      request.resource.data.status == 'active' &&
                      request.resource.data.priceSol is number &&
                      request.resource.data.priceSol > 0 &&
                      request.resource.data.priceSol <= 10000 &&
                      request.resource.data.title is string &&
                      request.resource.data.title.size() > 0 &&
                      request.resource.data.title.size() <= 80 &&
                      request.resource.data.description is string &&
                      request.resource.data.description.size() > 0 &&
                      request.resource.data.description.size() <= 1000 &&
                      request.resource.data.category in
                        ['beauty', 'fitness', 'health', 'education', 'food', 'lifestyle', 'general'] &&
                      validListingMediaUrls(request.resource.data);
      allow update: if isAuthed() && resource.data.sellerId == request.auth.uid &&
                      validListingMediaUrls(request.resource.data);
      allow delete: if false;
    }

    // Open gigs are public-readable; only the brand can mutate. Brands can
    // also read their own awarded/closed gigs.
    match /gigs/{gigId} {
      allow read: if (resource == null || resource.data.status == 'open') ||
                     (isAuthed() && resource.data.brandId == request.auth.uid);
      allow create: if isAuthed() &&
                      request.resource.data.brandId == request.auth.uid &&
                      request.resource.data.status == 'open' &&
                      request.resource.data.budgetSol is number &&
                      request.resource.data.budgetSol > 0 &&
                      request.resource.data.budgetSol <= 10000 &&
                      request.resource.data.title is string &&
                      request.resource.data.title.size() > 0 &&
                      request.resource.data.title.size() <= 80 &&
                      request.resource.data.description is string &&
                      request.resource.data.description.size() > 0 &&
                      request.resource.data.description.size() <= 1000 &&
                      request.resource.data.requirements is string &&
                      request.resource.data.requirements.size() <= 1000 &&
                      request.resource.data.category in
                        ['beauty', 'fitness', 'health', 'education', 'food', 'lifestyle', 'general'] &&
                      validListingMediaUrls(request.resource.data);
      allow update: if isAuthed() && resource.data.brandId == request.auth.uid &&
                      validListingMediaUrls(request.resource.data);
      allow delete: if false;
    }

    // Applications: visible to the creator who applied AND the brand running
    // the gig. Creators write the doc on apply; brands update status to
    // shortlist / award / reject.
    match /gigApplications/{applicationId} {
      allow read: if isAuthed() && (
        resource.data.creatorId == request.auth.uid ||
        resource.data.brandId == request.auth.uid ||
        get(/databases/$(database)/documents/gigs/$(resource.data.gigId)).data.brandId == request.auth.uid
      );
      // Create requires brandId to be the truthful brand of the parent gig
      // (we use get() to verify) so the brand can run cheap query-by-brandId
      // reads for the /applicants dashboard without a get() per row.
      //
      // Doc ID is forced to be `{gigId}_{creatorId}`, which gives us atomic
      // uniqueness for free — a second concurrent apply attempt by the same
      // creator hits the existing-doc path and falls under `update` rules,
      // which only the brand can satisfy. Defeats the spam-double-tap race.
      allow create: if isAuthed() &&
                      applicationId == request.resource.data.gigId + '_' + request.resource.data.creatorId &&
                      request.resource.data.creatorId == request.auth.uid &&
                      request.resource.data.status == 'pending' &&
                      request.resource.data.message is string &&
                      request.resource.data.message.size() > 0 &&
                      request.resource.data.message.size() <= 1000 &&
                      request.resource.data.sampleUrls is list &&
                      request.resource.data.sampleUrls.size() <= 4 &&
                      request.resource.data.gigId is string &&
                      request.resource.data.brandId is string &&
                      request.resource.data.brandId == get(/databases/$(database)/documents/gigs/$(request.resource.data.gigId)).data.brandId;
      // Brands can flip status only — never rewrite creatorId/gigId/message.
      allow update: if isAuthed() &&
                      resource.data.brandId == request.auth.uid &&
                      request.resource.data.diff(resource.data).affectedKeys()
                        .hasOnly(['status', 'updatedAt']) &&
                      request.resource.data.status in ['shortlisted', 'awarded', 'rejected'];
      allow delete: if false;
    }

    // Orders: visible to buyer and seller. Buyer creates the pending doc.
    // Updates are gated by a status state machine + immutable txSignature.
    //
    // Threat model note: clients ultimately self-attest payment by writing
    // `paid` with a `txSignature`. We cannot verify the on-chain transfer
    // in rules — that requires a Cloud Function listener. Until then, the
    // rule restricts WHO can flip WHICH transition (only the buyer can
    // claim "paid"; only the seller can claim "delivered"; etc.) so a
    // counterparty can't fabricate state for the other side.
    match /orders/{orderId} {
      allow read: if isAuthed() && (
        resource.data.buyerId == request.auth.uid ||
        resource.data.sellerId == request.auth.uid
      );
      allow create: if isAuthed() &&
                      request.resource.data.buyerId == request.auth.uid &&
                      request.resource.data.buyerId != request.resource.data.sellerId &&
                      request.resource.data.status == 'pending' &&
                      request.resource.data.txSignature == null &&
                      request.resource.data.amountSol is number &&
                      request.resource.data.amountSol > 0 &&
                      request.resource.data.amountSol <= 10000 &&
                      request.resource.data.type in ['service', 'gig'];
      allow update: if isAuthed() &&
                      (resource.data.buyerId == request.auth.uid ||
                       resource.data.sellerId == request.auth.uid) &&
                      request.resource.data.diff(resource.data).affectedKeys()
                        .hasOnly(['status', 'txSignature', 'updatedAt']) &&
                      // txSignature is append-only once set.
                      (
                        (resource.data.txSignature == null) ||
                        (resource.data.txSignature == request.resource.data.txSignature)
                      ) &&
                      // Legal status transitions (buyer-driven vs seller-driven).
                      (
                        // pending → paid: buyer claims payment + provides signature.
                        (resource.data.status == 'pending' &&
                         request.resource.data.status == 'paid' &&
                         resource.data.buyerId == request.auth.uid &&
                         request.resource.data.txSignature is string &&
                         request.resource.data.txSignature.size() > 0) ||
                        // pending → failed: buyer aborts.
                        (resource.data.status == 'pending' &&
                         request.resource.data.status == 'failed' &&
                         resource.data.buyerId == request.auth.uid) ||
                        // paid → delivered: seller marks delivered.
                        (resource.data.status == 'paid' &&
                         request.resource.data.status == 'delivered' &&
                         resource.data.sellerId == request.auth.uid) ||
                        // delivered → complete: buyer confirms receipt.
                        (resource.data.status == 'delivered' &&
                         request.resource.data.status == 'complete' &&
                         resource.data.buyerId == request.auth.uid) ||
                        // No-op (touching updatedAt) — status unchanged.
                        (resource.data.status == request.resource.data.status)
                      );
      allow delete: if false;
    }

    // Threads back the messaging primitive. One thread per
    // (kind, parentId) pair — `application_{appId}` for pre-award gig
    // negotiation, `order_{orderId}` for the contract phase. Both
    // participants are denormalized on the doc so the inbox can run a
    // single `participants array-contains` query (see indexes file).
    //
    // Threat model note: clients only write the message subdocument and
    // self-zero their own unreadCount entry. Thread metadata fan-out
    // (lastMessageAt, lastMessagePreview, counterparty unreadCount bump)
    // is owned by the onMessageCreate Cloud Function in functions/.
    function threadAt(threadId) {
      return get(/databases/$(database)/documents/threads/$(threadId)).data;
    }
    match /threads/{threadId} {
      // Arbiters get read-only access for dispute review (whitepaper §9
      // requires them to see the message log as evidence).
      allow read: if isAuthed() &&
                    (request.auth.uid in resource.data.participants ||
                     isArbiter());
      allow create: if isAuthed() &&
                      request.auth.uid in request.resource.data.participants &&
                      request.resource.data.participants.size() == 2 &&
                      request.resource.data.participants[0] != request.resource.data.participants[1] &&
                      request.resource.data.kind in ['application', 'order'] &&
                      request.resource.data.parentId is string &&
                      request.resource.data.parentId.size() > 0 &&
                      request.resource.data.unreadCount[request.resource.data.participants[0]] == 0 &&
                      request.resource.data.unreadCount[request.resource.data.participants[1]] == 0;
      // Clients may only self-zero their own unreadCount entry; everything
      // else is the Cloud Function's job (which uses admin creds and
      // bypasses rules).
      allow update: if isAuthed() &&
                      request.auth.uid in resource.data.participants &&
                      request.resource.data.diff(resource.data).affectedKeys()
                        .hasOnly(['unreadCount', 'updatedAt']) &&
                      request.resource.data.unreadCount.diff(resource.data.unreadCount)
                        .affectedKeys().hasOnly([request.auth.uid]) &&
                      request.resource.data.unreadCount[request.auth.uid] == 0;
      allow delete: if false;

      // Append-only message log. Whitepaper §9 treats this as evidence
      // during disputes — no edits, no deletes, no exceptions.
      match /messages/{messageId} {
        allow read: if isAuthed() &&
                      (request.auth.uid in threadAt(threadId).participants ||
                       isArbiter());
        allow create: if isAuthed() &&
                        request.resource.data.senderId == request.auth.uid &&
                        request.auth.uid in threadAt(threadId).participants &&
                        request.resource.data.body is string &&
                        request.resource.data.body.size() <= 2000 &&
                        request.resource.data.attachments is list &&
                        request.resource.data.attachments.size() <= 5 &&
                        request.resource.data.kind in
                          ['text', 'deliverable', 'revision_request', 'approval', 'system'];
        allow update: if false;
        allow delete: if false;
      }
    }

    // Reviews are public-readable. Each reviewer gets one review per order
    // (deterministic doc id `${orderId}_${reviewerId}`). Order must be in
    // the 'complete' state and the reviewer + reviewee must be the order's
    // two counter-parties.
    //
    // Schema (per whitepaper §7): four axes — scope, communication,
    // timeliness, quality — each 1..5. amountSol + listingId are
    // denormalized at write time and pinned to the parent order via the
    // rule, so the public reputation aggregate (weighted by deal size) can
    // run on a single collection without a join.
    function reviewedOrder(orderId) {
      return get(/databases/$(database)/documents/orders/$(orderId)).data;
    }
    function isValidAxes(axes) {
      return axes is map &&
             axes.scope is number && axes.scope >= 1 && axes.scope <= 5 &&
             axes.communication is number && axes.communication >= 1 && axes.communication <= 5 &&
             axes.timeliness is number && axes.timeliness >= 1 && axes.timeliness <= 5 &&
             axes.quality is number && axes.quality >= 1 && axes.quality <= 5;
    }
    match /reviews/{reviewId} {
      allow read: if true;
      allow create: if isAuthed() &&
                      request.resource.data.reviewerId == request.auth.uid &&
                      reviewId == request.resource.data.orderId + '_' + request.auth.uid &&
                      request.resource.data.reviewerId != request.resource.data.revieweeId &&
                      isValidAxes(request.resource.data.axes) &&
                      request.resource.data.comment is string &&
                      request.resource.data.comment.size() <= 500 &&
                      reviewedOrder(request.resource.data.orderId).status == 'complete' &&
                      request.auth.uid in [
                        reviewedOrder(request.resource.data.orderId).buyerId,
                        reviewedOrder(request.resource.data.orderId).sellerId,
                      ] &&
                      request.resource.data.revieweeId in [
                        reviewedOrder(request.resource.data.orderId).buyerId,
                        reviewedOrder(request.resource.data.orderId).sellerId,
                      ] &&
                      // amountSol + listingId must mirror the parent order
                      // exactly — they're the weight + per-listing key for
                      // the reputation aggregate, and a forged value would
                      // poison the public score.
                      request.resource.data.amountSol == reviewedOrder(request.resource.data.orderId).amountSol &&
                      request.resource.data.listingId == reviewedOrder(request.resource.data.orderId).listingId;
      // Edits are limited to axes + comment (the reviewer's opinion). The
      // contract-level fields (amountSol, listingId, revieweeId, orderId)
      // can never change.
      allow update: if isAuthed() &&
                      resource.data.reviewerId == request.auth.uid &&
                      request.resource.data.diff(resource.data).affectedKeys()
                        .hasOnly(['axes', 'comment']) &&
                      isValidAxes(request.resource.data.axes) &&
                      request.resource.data.comment is string &&
                      request.resource.data.comment.size() <= 500;
      allow delete: if false;
    }

    // Per-user notification preferences. Doc id == owner uid. Default
    // (no doc) means "everything on" — preferencesService falls back to
    // that on read. Writes only by the owner; the Cloud Function's
    // emitNotification helper uses admin creds to read the doc and gate
    // each fan-out.
    match /preferences/{uid} {
      allow read, write: if isOwner(uid);
    }

    // Roles assign elevated capabilities (arbiter for v1). Public read so
    // both rules and clients can `exists()`/get-check the doc; writes are
    // admin-only — you provision arbiters by writing the doc directly via
    // firebase-cli or the console.
    match /roles/{uid} {
      allow read: if true;
      allow create, update, delete: if false;
    }

    // Disputes (whitepaper §9). One per order — deterministic doc id is
    // the orderId. Either side may file before the order is `complete`.
    // Outcomes are recorded for the public profile but SOL doesn't move
    // on-chain in v1; the Anchor program in adler-program will replay
    // resolved disputes once it ships.
    function disputedOrder(orderId) {
      return get(/databases/$(database)/documents/orders/$(orderId)).data;
    }
    match /disputes/{disputeId} {
      // Visible to either party of the dispute and to arbiters.
      allow read: if isAuthed() && (
        resource.data.buyerId == request.auth.uid ||
        resource.data.sellerId == request.auth.uid ||
        isArbiter()
      );
      // Filing rules: caller is one of the order's two parties; the
      // order is in flight (paid or delivered — disputes after `complete`
      // are blocked since the brand has had its last word per §9); the
      // dispute is keyed deterministically by orderId so a second file
      // attempt falls under the update rule and is rejected for the
      // counterparty.
      allow create: if isAuthed() &&
                      disputeId == request.resource.data.orderId &&
                      request.resource.data.filedBy in ['buyer', 'seller'] &&
                      request.resource.data.status == 'open' &&
                      request.resource.data.outcome == null &&
                      request.resource.data.reason is string &&
                      request.resource.data.reason.size() > 0 &&
                      request.resource.data.reason.size() <= 2000 &&
                      request.auth.uid in [
                        request.resource.data.buyerId,
                        request.resource.data.sellerId,
                      ] &&
                      request.resource.data.buyerId == disputedOrder(request.resource.data.orderId).buyerId &&
                      request.resource.data.sellerId == disputedOrder(request.resource.data.orderId).sellerId &&
                      request.resource.data.amountSol == disputedOrder(request.resource.data.orderId).amountSol &&
                      request.resource.data.listingId == disputedOrder(request.resource.data.orderId).listingId &&
                      disputedOrder(request.resource.data.orderId).status in ['paid', 'delivered'];
      // Arbiter-only resolution. Restricted to the outcome fields so the
      // contract-level snapshot (buyerId, sellerId, amountSol, listingId,
      // filedBy, reason) stays frozen.
      allow update: if isArbiter() &&
                      request.resource.data.diff(resource.data).affectedKeys()
                        .hasOnly(['status', 'outcome', 'outcomeNote',
                                  'splitPercentToCreator', 'resolvedBy',
                                  'resolvedAt', 'updatedAt']) &&
                      resource.data.status == 'open' &&
                      request.resource.data.status == 'resolved' &&
                      request.resource.data.outcome in
                        ['release_to_creator', 'refund_to_brand', 'split'] &&
                      request.resource.data.resolvedBy == request.auth.uid &&
                      request.resource.data.outcomeNote is string &&
                      request.resource.data.outcomeNote.size() <= 2000 &&
                      (
                        (request.resource.data.outcome != 'split') ||
                        (request.resource.data.splitPercentToCreator is number &&
                         request.resource.data.splitPercentToCreator >= 0 &&
                         request.resource.data.splitPercentToCreator <= 100)
                      );
      allow delete: if false;
    }

    // Notifications: server-only writer. Cloud Functions use admin creds
    // and bypass `allow create: if false`. Recipients can read their own
    // and flip the `read` flag to true; nothing else from a client.
    match /notifications/{notificationId} {
      allow read: if isAuthed() &&
                    resource.data.recipientId == request.auth.uid;
      allow update: if isAuthed() &&
                      resource.data.recipientId == request.auth.uid &&
                      request.resource.data.diff(resource.data).affectedKeys()
                        .hasOnly(['read']) &&
                      request.resource.data.read == true;
      allow create, delete: if false;
    }

    // Email outbox for the firebase/firestore-send-email extension. The
    // Cloud Function `onNotificationCreateEmail` writes `{ to, message }`
    // docs here via the admin SDK; the extension reads them with its own
    // service account. Clients are denied entirely — no one tampers with
    // the outbox.
    match /mail/{id} {
      allow read, write: if false;
    }
  }
}
