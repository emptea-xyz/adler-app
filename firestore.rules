rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthed() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isAuthed() && request.auth.uid == uid;
    }

    function isGroupMember(groupId) {
      return isAuthed()
             && groupId is string
             && exists(/databases/$(database)/documents/groupMembers/$(groupId + '_' + request.auth.uid));
    }

    function isGroupAdmin(groupId) {
      return isAuthed()
             && groupId is string
             && exists(/databases/$(database)/documents/groupMembers/$(groupId + '_' + request.auth.uid))
             && get(/databases/$(database)/documents/groupMembers/$(groupId + '_' + request.auth.uid)).data.role == 'admin';
    }

    function groupIsActive(groupId) {
      return exists(/databases/$(database)/documents/groups/$(groupId))
             && get(/databases/$(database)/documents/groups/$(groupId)).data.status == 'active';
    }

    // ── Profiles ────────────────────────────────────────────────────────
    // Public read; owner-only write with field validation.
    function validUsername(v) {
      return v is string && v.matches('^[a-z0-9_]{3,20}$');
    }
    function validDisplayName(v) {
      return v is string && v.size() > 0 && v.size() <= 50;
    }
    function validBio(v) {
      return v is string && v.size() <= 280;
    }
    function validLocation(v) {
      return v is map && v.kind in ['country', 'global'] &&
             (v.kind == 'global'
                || (v.country is string && v.country.size() == 2));
    }
    // Solana base58 addresses are 32–44 chars. Cap at 44 to reject
    // 1MB-string injection on first-set of `walletAddress`.
    function validWalletAddress(v) {
      return v is string && v.size() >= 32 && v.size() <= 44;
    }

    match /profiles/{userId} {
      allow read: if true;
      allow create: if isOwner(userId)
                    && request.resource.data.id == userId
                    && validUsername(request.resource.data.username)
                    && validDisplayName(request.resource.data.displayName)
                    && validBio(request.resource.data.bio);
      // Allowlist of fields the client may mutate. Any field outside this
      // set (e.g. `verified`, `xp`, `latestActivityAt`, `groupCount`,
      // future schema additions) is server-only and a client-side write
      // is rejected. See H1.
      allow update: if isOwner(userId)
                    && request.resource.data.diff(resource.data).affectedKeys()
                         .hasOnly(['username','displayName','bio','walletAddress',
                                   'location','avatarUrl','dmContact',
                                   'lastUsernameChangeAt','updatedAt'])
                    // Append-only walletAddress. First set requires a real
                    // base58 string; subsequent updates must preserve.
                    && (
                      (resource.data.get('walletAddress', null) == null
                       && (request.resource.data.get('walletAddress', null) == null
                           || validWalletAddress(request.resource.data.walletAddress)))
                      || request.resource.data.walletAddress == resource.data.walletAddress
                    )
                    && validUsername(request.resource.data.username)
                    && validDisplayName(request.resource.data.displayName)
                    && validBio(request.resource.data.bio)
                    // Location is optional on legacy profiles. If present, must validate.
                    && (request.resource.data.get('location', null) == null
                        || validLocation(request.resource.data.location))
                    // Username change: rate-limited to once every 30 days
                    // (2_592_000_000 ms). lastUsernameChangeAt must equal
                    // request.time so clients can't backdate it.
                    && (
                      // (a) Username preserved → lastUsernameChangeAt must
                      //     also be preserved (closes the H2 backdate hole).
                      (request.resource.data.username == resource.data.username
                       && request.resource.data.get('lastUsernameChangeAt', null)
                           == resource.data.get('lastUsernameChangeAt', null))
                      // (b) Username changed → cooldown elapsed (or never set)
                      //     AND new lastUsernameChangeAt is the server clock.
                      || (
                        (resource.data.get('lastUsernameChangeAt', null) == null
                          || request.time.toMillis()
                              - resource.data.lastUsernameChangeAt.toMillis() >= 2592000000)
                        && request.resource.data.lastUsernameChangeAt == request.time
                      )
                    );
      allow delete: if false;
    }

    match /profilePrivate/{userId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId)
                    && request.resource.data.keys().hasOnly(['pushToken','updatedAt'])
                    && request.resource.data.updatedAt == request.time
                    && (request.resource.data.get('pushToken', null) == null
                        || (request.resource.data.pushToken is string
                            && request.resource.data.pushToken.size() <= 512));
      allow update: if isOwner(userId)
                    && request.resource.data.diff(resource.data).affectedKeys()
                         .hasOnly(['pushToken','updatedAt'])
                    && request.resource.data.updatedAt == request.time
                    && (request.resource.data.get('pushToken', null) == null
                        || (request.resource.data.pushToken is string
                            && request.resource.data.pushToken.size() <= 512));
      allow delete: if false;
    }

    match /usernames/{slug} {
      allow read: if true;
      allow create: if isAuthed()
                    && request.resource.data.userId == request.auth.uid
                    && slug.matches('^[a-z0-9_]{3,20}$');
      allow update: if false;
      allow delete: if isAuthed() && resource.data.userId == request.auth.uid;
    }

    // ── Bounties ────────────────────────────────────────────────────────
    // Single-mode (manual), single-window (30d submissions + 90d review).
    // Total lifetime: 120 days before refund unlocks.
    function bountyValidShape(d) {
      return d.posterId is string
             && d.title is string && d.title.size() > 0 && d.title.size() <= 80
             && d.prompt is string && d.prompt.size() > 0 && d.prompt.size() <= 500
             && d.bountyLamports is int
             && d.bountyLamports > 0
             // 10 000 SOL ceiling (M2). Below 2^63-1, well above any plausible bounty.
             && d.bountyLamports <= 10000000000000
             && d.scope in ['public', 'group']
             && d.contractIdHex is string && d.contractIdHex.matches('^[0-9a-f]{64}$')
             && d.posterWalletAddress is string
             && d.submissionKind in ['photo', 'video', 'link']
             && d.submissionEndsAt is int
             // M3: submission window must not be already-closed at create.
             && d.submissionEndsAt > request.time.toMillis()
             && d.expiresAt is int
             // Timestamps are unix-ms. 90 days review = 7_776_000_000 ms.
             && d.expiresAt == d.submissionEndsAt + 7776000000
             && d.submissionCount is int && d.submissionCount == 0
             // H4: escrowFunded starts false; gets flipped true after on-chain
             // create_bounty lands. Settle path gates on this being true.
             && d.get('escrowFunded', false) == false;
    }

    // Returns the parent bounty's submissionKind for cross-doc validation
    // in the submission create rule (M5).
    function bountyKindFor(bountyId) {
      return get(/databases/$(database)/documents/bounties/$(bountyId)).data.submissionKind;
    }

    function bountyFor(bountyId) {
      return get(/databases/$(database)/documents/bounties/$(bountyId)).data;
    }

    function canReadBountyData(bounty) {
      return isOwner(bounty.posterId)
             || (isAuthed()
                 && bounty.status != 'hidden'
                 && (bounty.scope == 'public'
                     || isGroupMember(bounty.groupId)));
    }

    function canReadBountyId(bountyId) {
      return canReadBountyData(bountyFor(bountyId));
    }

    function canSubmitToBounty(bountyId) {
      let bounty = bountyFor(bountyId);
      return canReadBountyData(bounty)
             && bounty.status == 'open'
             && bounty.get('escrowFunded', false) == true
             && bounty.submissionEndsAt is int
             && bounty.submissionEndsAt > request.time.toMillis();
    }

    function validSubmissionPreview(d) {
      return d.get('photoStoragePath', '') is string
             && d.get('photoStoragePath', '').size() <= 512
             && d.get('videoStoragePath', '') is string
             && d.get('videoStoragePath', '').size() <= 512
             && d.get('bountyTitle', '') is string
             && d.get('bountyTitle', '').size() <= 80
             && d.get('bountyLamports', 0) is int
             && d.get('bountyLamports', 0) >= 0
             && d.get('bountyStatus', 'open') in ['open', 'in_review', 'cancelling', 'hidden', 'settled', 'refunded']
             && d.get('bountyPosterId', '') is string
             && d.get('bountyPosterId', '').size() <= 128
             && d.get('bountySubmissionKind', 'photo') in ['photo', 'video', 'link']
             && d.get('bountyScope', 'public') in ['public', 'group']
             && (d.get('bountyGroupId', null) == null || d.bountyGroupId is string);
    }

    match /bounties/{id} {
      // Hidden bounties only visible to poster + super-admin queue (server).
      allow read: if canReadBountyData(resource.data);
      allow create: if isOwner(request.resource.data.posterId)
                    && bountyValidShape(request.resource.data)
                    && request.resource.data.status == 'open'
                    && request.resource.data.reportCount == 0
                    // M1: posterWalletAddress must match the authenticated
                    // user's profile — clients can't claim someone else's
                    // wallet on the bounty doc.
                    && request.resource.data.posterWalletAddress
                        == get(/databases/$(database)/documents/profiles/$(request.auth.uid)).data.walletAddress
                    // M6: scope=='public' must not carry a stray groupId.
                    && ((request.resource.data.scope == 'public'
                         && request.resource.data.get('groupId', null) == null)
                        || (request.resource.data.scope == 'group'
                            && request.resource.data.groupId is string
                            && isGroupMember(request.resource.data.groupId)));
      // Owner update paths:
      //   (a) status preserved: flipping `escrowFunded` from false to true
      //       only (one-way; H4 transition guard).
      //   (b) open|in_review → settled: poster signed `settle_manual_bounty`
      //       on-chain and writes the on-chain tx signature + winner refs.
      //       Requires escrowFunded == true (H4) and a non-empty base58
      //       signature shape.
      //   (c)–(e) Cancel state machine.
      // Refund + hidden flips are Cloud-Function-only.
      allow update: if isOwner(resource.data.posterId)
                    && request.resource.data.posterId == resource.data.posterId
                    && request.resource.data.bountyLamports == resource.data.bountyLamports
                    && request.resource.data.contractIdHex == resource.data.contractIdHex
                    && request.resource.data.reportCount == resource.data.reportCount
                    && request.resource.data.submissionEndsAt == resource.data.submissionEndsAt
                    && request.resource.data.expiresAt == resource.data.expiresAt
                    && request.resource.data.get('submissionCount', 0)
                        == resource.data.get('submissionCount', 0)
                    && (
                      // (a) Status preserved. `escrowFunded` may transition
                      //     false→true only — never the reverse.
                      (resource.data.status == request.resource.data.status
                       && request.resource.data.status in ['open', 'in_review']
                       && (resource.data.get('escrowFunded', false) == false
                           || request.resource.data.get('escrowFunded', false) == true))
                      // (b) Manual settle: poster picks a winner in either `open` (early)
                      //     or `in_review` (after submission window). Must be before
                      //     refund-unlock (`expiresAt`). Requires the escrow to have
                      //     actually been funded on-chain (H4).
                      || ((resource.data.status == 'open' || resource.data.status == 'in_review')
                          && request.resource.data.status == 'settled'
                          && request.resource.data.winnerId is string
                          && request.resource.data.winningSubmissionId is string
                          && request.resource.data.txSignature is string
                          && request.resource.data.txSignature.size() >= 64
                          && request.resource.data.txSignature.size() <= 128
                          && resource.data.get('escrowFunded', false) == true
                          && request.time.toMillis() < resource.data.expiresAt)
                      // (c) Cancel — step 1: poster claims the lock. Atomic with
                      //     `enforceSubmissionCap` so a racing submitter can't
                      //     slip in. Must record `cancellingFromStatus` so the
                      //     revert path (e) knows what to restore.
                      || ((resource.data.status == 'open' || resource.data.status == 'in_review')
                          && request.resource.data.status == 'cancelling'
                          && resource.data.get('submissionCount', 0) == 0
                          && request.resource.data.cancellingFromStatus == resource.data.status)
                      // (d) Cancel — step 2 (success): on-chain ix landed, write
                      //     the tx signature and finalise as refunded. Same
                      //     terminal as the auto-expire path so downstream
                      //     consumers stay simple.
                      || (resource.data.status == 'cancelling'
                          && request.resource.data.status == 'refunded'
                          && request.resource.data.txSignature is string)
                      // (e) Cancel — step 2 (abort): on-chain ix failed; roll back
                      //     to whichever status we recorded at step 1.
                      || (resource.data.status == 'cancelling'
                          && request.resource.data.status == resource.data.cancellingFromStatus)
                    );
      allow delete: if false;
    }

    // ── Submissions ─────────────────────────────────────────────────────
    // One submission per user per bounty. The deterministic doc id
    // `${bountyId}_${submitterId}` is the hard gate — a second create
    // from the same user collides and is rejected. The
    // `enforceSubmissionCap` Cloud Function is a defensive backstop.
    match /submissions/{id} {
      allow read: if canReadBountyId(resource.data.bountyId);
      // M4: cap URL sizes. M5: cross-validate `kind` against parent bounty.
      allow create: if isOwner(request.resource.data.submitterId)
                    && request.resource.data.keys()
                         .hasOnly(['bountyId','submitterId','photoUrl','photoStoragePath',
                                   'videoUrl','videoStoragePath','linkUrl','submittedAt',
                                   'isWinner','bountyTitle','bountyLamports','bountyStatus',
                                   'bountyPosterId','bountySubmissionKind','bountyScope',
                                   'bountyGroupId'])
                    && request.resource.data.bountyId is string
                    && request.resource.data.photoUrl is string
                    && request.resource.data.photoUrl.size() <= 2048
                    && request.resource.data.videoUrl is string
                    && request.resource.data.videoUrl.size() <= 2048
                    && request.resource.data.get('linkUrl', '') is string
                    && request.resource.data.get('linkUrl', '').size() <= 2048
                    && (request.resource.data.get('linkUrl', '') == ''
                        || request.resource.data.linkUrl.matches('^https?://.+'))
                    && request.resource.data.isWinner == false
                    && request.resource.data.submittedAt == request.time
                    && validSubmissionPreview(request.resource.data)
                    && id == request.resource.data.bountyId + '_' + request.auth.uid
                    && canSubmitToBounty(request.resource.data.bountyId)
                    && (
                      (bountyKindFor(request.resource.data.bountyId) == 'photo'
                       && request.resource.data.photoUrl != ''
                       && request.resource.data.videoUrl == ''
                       && request.resource.data.get('linkUrl', '') == '')
                      || (bountyKindFor(request.resource.data.bountyId) == 'video'
                          && request.resource.data.videoUrl != ''
                          && request.resource.data.photoUrl == ''
                          && request.resource.data.get('linkUrl', '') == '')
                      || (bountyKindFor(request.resource.data.bountyId) == 'link'
                          && request.resource.data.get('linkUrl', '') != ''
                          && request.resource.data.photoUrl == ''
                          && request.resource.data.videoUrl == '')
                    );
      // Submitter can withdraw their own submission until the poster
      // marks them the winner.
      allow update: if false;
      allow delete: if isOwner(resource.data.submitterId)
                    && resource.data.isWinner == false;
    }

    // ── Reports ─────────────────────────────────────────────────────────
    // Deterministic doc id: ${bountyId}_${reporterId}.
    match /reports/{id} {
      allow read: if isOwner(resource.data.reporterId);
      allow create: if isOwner(request.resource.data.reporterId)
                    && request.resource.data.bountyId is string
                    && canReadBountyId(request.resource.data.bountyId)
                    && request.resource.data.reason is string
                    && request.resource.data.reason.size() > 0
                    && request.resource.data.reason.size() <= 200
                    && id == request.resource.data.bountyId + '_' + request.auth.uid;
      allow update: if false;
      allow delete: if false;
    }

    // ── Groups ──────────────────────────────────────────────────────────
    match /groups/{id} {
      allow read: if isAuthed();
      // V2 admin-managed model: all writes (create / update name+description /
      // delete) go through Cloud Functions — super-admin creates + activates,
      // group-admin edits. No client-direct mutations.
      allow create, update, delete: if false;
    }

    match /groupMembers/{compoundId} {
      // Any authed user can read members of an active group — the members
      // list is public surface inside a group.
      allow read: if isAuthed() && groupIsActive(resource.data.groupId);
      // Server-only writes via addGroupMember / removeGroupMember /
      // approveJoinRequest Cloud Functions.
      allow create, update, delete: if false;
    }

    // ── Join requests ──────────────────────────────────────────────────
    // Doc id format: `${groupId}_${uid}` — deterministic so a user can't
    // queue multiple pending requests for the same group.
    match /joinRequests/{id} {
      allow read: if isAuthed()
                  && (resource.data.uid == request.auth.uid
                      || isGroupAdmin(resource.data.groupId));
      // All writes go through requestToJoinGroup /
      // approveJoinRequest / rejectJoinRequest Cloud Functions.
      allow create, update, delete: if false;
    }

    // ── Notifications ───────────────────────────────────────────────────
    match /notifications/{id} {
      allow read: if isOwner(resource.data.recipientId);
      // Owner can flip `read` from false to true — and nothing else. M7.
      allow update: if isOwner(resource.data.recipientId)
                    && request.resource.data.diff(resource.data).affectedKeys()
                         .hasOnly(['read'])
                    && request.resource.data.read == true
                    && resource.data.read == false;
      // Server-only create + delete.
      allow create, delete: if false;
    }

    // ── Preferences ─────────────────────────────────────────────────────
    match /preferences/{uid} {
      allow read, write: if isOwner(uid);
    }
  }
}
