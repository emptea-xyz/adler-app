rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthed() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isAuthed() && request.auth.uid == uid;
    }

    // ── Profiles ────────────────────────────────────────────────────────
    // Public read; owner-only write with field validation.
    function validUsername(v) {
      return v is string && v.matches('^[a-z0-9_]{3,20}$');
    }
    function validDisplayName(v) {
      return v is string && v.size() > 0 && v.size() <= 50;
    }
    function validBio(v) {
      return v is string && v.size() <= 280;
    }
    function validLocation(v) {
      return v is map && v.kind in ['country', 'global'] &&
             (v.kind == 'global'
                || (v.country is string && v.country.size() == 2));
    }

    match /profiles/{userId} {
      allow read: if true;
      allow create: if isOwner(userId)
                    && request.resource.data.id == userId
                    && validUsername(request.resource.data.username)
                    && validDisplayName(request.resource.data.displayName)
                    && validBio(request.resource.data.bio);
      allow update: if isOwner(userId)
                    // Append-only walletAddress.
                    && (resource.data.walletAddress == null
                        || request.resource.data.walletAddress == resource.data.walletAddress)
                    && validUsername(request.resource.data.username)
                    && validDisplayName(request.resource.data.displayName)
                    && validBio(request.resource.data.bio)
                    // Location is optional on legacy profiles. If present, must validate.
                    && (request.resource.data.get('location', null) == null
                        || validLocation(request.resource.data.location))
                    // groupCount + latestActivityAt are server-only fields — must
                    // not change on a client update. .get() tolerates legacy
                    // profiles where the field never existed.
                    && (request.resource.data.get('groupCount', 0)
                        == resource.data.get('groupCount', 0))
                    // Username change: rate-limited to once every 30 days
                    // (2_592_000_000 ms). lastUsernameChangeAt must equal
                    // request.time so clients can't backdate it.
                    && (
                      // (a) Username preserved → no cooldown bookkeeping required.
                      request.resource.data.username == resource.data.username
                      // (b) Username changed → cooldown elapsed (or never set)
                      //     AND new lastUsernameChangeAt is the server clock.
                      || (
                        (resource.data.get('lastUsernameChangeAt', null) == null
                          || request.time.toMillis()
                              - resource.data.lastUsernameChangeAt.toMillis() >= 2592000000)
                        && request.resource.data.lastUsernameChangeAt == request.time
                      )
                    );
      allow delete: if false;
    }

    match /usernames/{slug} {
      allow read: if true;
      allow create: if isAuthed()
                    && request.resource.data.userId == request.auth.uid
                    && slug.matches('^[a-z0-9_]{3,20}$');
      allow update: if false;
      allow delete: if isAuthed() && resource.data.userId == request.auth.uid;
    }

    // ── Bounties ────────────────────────────────────────────────────────
    // Single-mode (manual), single-window (30d submissions + 90d review).
    // Total lifetime: 120 days before refund unlocks.
    function bountyValidShape(d) {
      return d.posterId is string
             && d.title is string && d.title.size() > 0 && d.title.size() <= 80
             && d.prompt is string && d.prompt.size() > 0 && d.prompt.size() <= 500
             && d.bountyLamports is int && d.bountyLamports > 0
             && d.scope in ['public', 'group']
             && d.contractIdHex is string && d.contractIdHex.matches('^[0-9a-f]{64}$')
             && d.posterWalletAddress is string
             && d.submissionKind in ['photo', 'video', 'link']
             && d.submissionEndsAt is int
             && d.expiresAt is int
             // Timestamps are unix-ms. 90 days review = 7_776_000_000 ms.
             && d.expiresAt == d.submissionEndsAt + 7776000000
             && d.submissionCount is int && d.submissionCount == 0;
    }

    match /bounties/{id} {
      // Hidden bounties only visible to poster + super-admin queue (server).
      allow read: if resource.data.status != 'hidden'
                  || isOwner(resource.data.posterId);
      allow create: if isOwner(request.resource.data.posterId)
                    && bountyValidShape(request.resource.data)
                    && request.resource.data.status == 'open'
                    && request.resource.data.reportCount == 0
                    && (request.resource.data.scope == 'public'
                        || (request.resource.data.scope == 'group'
                            && request.resource.data.groupId is string));
      // Owner update paths:
      //   (a) status preserved: e.g. flipping `escrowFunded` from false to true.
      //   (b) open|in_review → settled: poster signed `settle_manual_bounty`
      //       on-chain and writes the on-chain tx signature + winner refs.
      // Refund + hidden flips are Cloud-Function-only.
      allow update: if isOwner(resource.data.posterId)
                    && request.resource.data.posterId == resource.data.posterId
                    && request.resource.data.bountyLamports == resource.data.bountyLamports
                    && request.resource.data.contractIdHex == resource.data.contractIdHex
                    && request.resource.data.reportCount == resource.data.reportCount
                    && request.resource.data.submissionEndsAt == resource.data.submissionEndsAt
                    && request.resource.data.expiresAt == resource.data.expiresAt
                    && request.resource.data.get('submissionCount', 0)
                        == resource.data.get('submissionCount', 0)
                    && (
                      // (a) Status preserved (e.g. flipping `escrowFunded` from false to true).
                      (resource.data.status == request.resource.data.status
                       && request.resource.data.status in ['open', 'in_review'])
                      // (b) Manual settle: poster picks a winner in either `open` (early)
                      //     or `in_review` (after submission window). Must be before
                      //     refund-unlock (`expiresAt`).
                      || ((resource.data.status == 'open' || resource.data.status == 'in_review')
                          && request.resource.data.status == 'settled'
                          && request.resource.data.winnerId is string
                          && request.resource.data.winningSubmissionId is string
                          && request.resource.data.txSignature is string
                          && request.time.toMillis() < resource.data.expiresAt)
                      // (c) Cancel — step 1: poster claims the lock. Atomic with
                      //     `enforceSubmissionCap` so a racing submitter can't
                      //     slip in. Must record `cancellingFromStatus` so the
                      //     revert path (e) knows what to restore.
                      //     .get() tolerates legacy docs where submissionCount was never set.
                      || ((resource.data.status == 'open' || resource.data.status == 'in_review')
                          && request.resource.data.status == 'cancelling'
                          && resource.data.get('submissionCount', 0) == 0
                          && request.resource.data.cancellingFromStatus == resource.data.status)
                      // (d) Cancel — step 2 (success): on-chain ix landed, write
                      //     the tx signature and finalise as refunded. Same
                      //     terminal as the auto-expire path so downstream
                      //     consumers stay simple.
                      || (resource.data.status == 'cancelling'
                          && request.resource.data.status == 'refunded'
                          && request.resource.data.txSignature is string)
                      // (e) Cancel — step 2 (abort): on-chain ix failed; roll back
                      //     to whichever status we recorded at step 1.
                      || (resource.data.status == 'cancelling'
                          && request.resource.data.status == resource.data.cancellingFromStatus)
                    );
      allow delete: if false;
    }

    // ── Submissions ─────────────────────────────────────────────────────
    // One submission per user per bounty. The deterministic doc id
    // `${bountyId}_${submitterId}` is the hard gate — a second create
    // from the same user collides and is rejected. The
    // `enforceSubmissionCap` Cloud Function is a defensive backstop.
    match /submissions/{id} {
      allow read: if true;
      allow create: if isOwner(request.resource.data.submitterId)
                    && request.resource.data.bountyId is string
                    && request.resource.data.photoUrl is string
                    && request.resource.data.videoUrl is string
                    && request.resource.data.isWinner == false
                    && id == request.resource.data.bountyId + '_' + request.auth.uid;
      // Submitter can withdraw their own submission until the poster
      // marks them the winner.
      allow update: if false;
      allow delete: if isOwner(resource.data.submitterId)
                    && resource.data.isWinner == false;
    }

    // ── Reports ─────────────────────────────────────────────────────────
    // Deterministic doc id: ${bountyId}_${reporterId}.
    match /reports/{id} {
      allow read: if isOwner(resource.data.reporterId);
      allow create: if isOwner(request.resource.data.reporterId)
                    && request.resource.data.bountyId is string
                    && request.resource.data.reason is string
                    && request.resource.data.reason.size() > 0
                    && request.resource.data.reason.size() <= 200
                    && id == request.resource.data.bountyId + '_' + request.auth.uid;
      allow update: if false;
      allow delete: if false;
    }

    // ── Groups ──────────────────────────────────────────────────────────
    match /groups/{id} {
      allow read: if isAuthed();
      // Server-only writes (Cloud Function approveGroupCreation).
      allow create, update, delete: if false;
    }

    match /groupMembers/{compoundId} {
      // Members read their own membership doc; admins read any in their group.
      allow read: if isAuthed()
                  && (resource.data.uid == request.auth.uid
                      || (exists(/databases/$(database)/documents/groupMembers/$(resource.data.groupId + '_' + request.auth.uid))
                          && get(/databases/$(database)/documents/groupMembers/$(resource.data.groupId + '_' + request.auth.uid)).data.role == 'admin'));
      // All writes are server-only. Super-admin seeds 'admin' role via
      // direct Firestore writes (bypasses rules).
      allow create, update, delete: if false;
    }

    match /joinRequests/{id} {
      allow read: if isAuthed()
                  && (resource.data.uid == request.auth.uid
                      || (exists(/databases/$(database)/documents/groupMembers/$(resource.data.groupId + '_' + request.auth.uid))
                          && get(/databases/$(database)/documents/groupMembers/$(resource.data.groupId + '_' + request.auth.uid)).data.role == 'admin'));
      // Deterministic doc id: ${groupId}_${uid}.
      allow create: if isOwner(request.resource.data.uid)
                    && request.resource.data.groupId is string
                    && request.resource.data.status == 'pending'
                    && id == request.resource.data.groupId + '_' + request.auth.uid;
      // Admin approve/reject is server-only.
      allow update, delete: if false;
    }

    match /groupCreationRequests/{id} {
      allow read: if isOwner(resource.data.requesterId);
      allow create: if isOwner(request.resource.data.requesterId)
                    && request.resource.data.name is string
                    && request.resource.data.name.size() > 0
                    && request.resource.data.name.size() <= 60
                    && request.resource.data.description is string
                    && request.resource.data.description.size() <= 200
                    && request.resource.data.status == 'pending';
      allow update, delete: if false;
    }

    // ── Notifications ───────────────────────────────────────────────────
    match /notifications/{id} {
      allow read: if isOwner(resource.data.recipientId);
      // Owner can flip read flag only.
      allow update: if isOwner(resource.data.recipientId)
                    && request.resource.data.recipientId == resource.data.recipientId
                    && request.resource.data.kind == resource.data.kind
                    && request.resource.data.title == resource.data.title
                    && request.resource.data.body == resource.data.body
                    && request.resource.data.href == resource.data.href
                    && request.resource.data.refs == resource.data.refs;
      // Server-only create + delete.
      allow create, delete: if false;
    }

    // ── Preferences ─────────────────────────────────────────────────────
    match /preferences/{uid} {
      allow read, write: if isOwner(uid);
    }
  }
}
